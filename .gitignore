# --- Secrets ---------------------------------------------------------------
# Never commit the real .env (API tokens). Commit .env.example as a template.
.env
.env.local
.env.*.local
*.pem
*.key

# --- Pipeline outputs ------------------------------------------------------
# pyvis 'local' mode dumps a vis-network bundle into lib/ next to every
# network.html. With cdn_resources='remote' in network.py this shouldn't be
# generated, but ignore defensively in case pyvis behaviour changes.
lib/

# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# --- Editor / OS -----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Jupyter ---------------------------------------------------------------
.ipynb_checkpoints/

# --- Inputs (keep PDFs/JSON configs tracked; ignore scratch) ---------------
# Any scratch / personal copies:
pdf_input/_scratch/
site_input/_scratch/
