oter></div><script src=\"https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=68227ab77271320729baa06e\" type=\"text/javascript\" integrity=\"sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=\" crossorigin=\"anonymous\"></script><script src=\"https://cdn.prod.website-files.com/68227ab77271320729baa06e/js/webflow.schunk.36b8fb49256177c8.js\" type=\"text/javascript\" integrity=\"sha384-4abIlA5/v7XaW1HMXKBgnUuhnjBYJ/Z9C1OSg4OhmVw9O3QeHJ/qJqFBERCDPv7G\" crossorigin=\"anonymous\"></script><script src=\"https://cdn.prod.website-files.com/68227ab77271320729baa06e/js/webflow.c232cf87.46878ccc9e1904d8.js\" type=\"text/javascript\" integrity=\"sha384-P5aC7uaqHvKwtO4HxQla7dQwA5J+Qrdh1rDJAwG1Y8S1M0BPEFE9wKos6A87aAC3\" crossorigin=\"anonymous\"></script><script src=\"https://cdn.prod.website-files.com/gsap/3.15.0/gsap.min.js\" type=\"text/javascript\"></script><script src=\"https://cdn.prod.website-files.com/gsap/3.15.0/ScrollTrigger.min.js\" type=\"text/javascript\"></script><script src=\"https://cdn.prod.website-files.com/gsap/3.15.0/SplitText.min.js\" type=\"text/javascript\"></script><script type=\"text/javascript\">gsap.registerPlugin(ScrollTrigger,SplitText);</script><script>\n  (function wrapStarredText(node) {\n    // Only process element nodes\n    if (node.nodeType === Node.ELEMENT_NODE) {\n      // Don't dive into script or style tags\n      if (['SCRIPT','STYLE'].includes(node.tagName)) return;\n      Array.from(node.childNodes).forEach(wrapStarredText);\n    }\n    // Process text nodes\n    else if (node.nodeType === Node.TEXT_NODE) {\n      const txt = node.textContent;\n      // Regex: match *some text* (non-greedy)\n      const RE = /\\*(.+?)\\*/g;\n      let match, lastIndex = 0;\n      const frag = document.createDocumentFragment();\n      \n      while ((match = RE.exec(txt)) !== null) {\n        // text before the match\n        const before = txt.slice(lastIndex, match.index);\n        if (before) frag.appendChild(document.createTextNode(before));\n        \n        // create the highlighting span\n        const span = document.createElement('span');\n        span.className = 'text-color-secondary';\n        span.textContent = match[1];\n        frag.appendChild(span);\n        \n        lastIndex = match.index + match[0].length;\n      }\n      \n      // any trailing text\n      const after = txt.slice(lastIndex);\n      if (after) frag.appendChild(document.createTextNode(after));\n      \n      // if we found any matches, swap in the fragment\n      if (frag.childNodes.length) {\n        node.parentNode.replaceChild(frag, node);\n      }\n    }\n  })(document.body);\n</script>\n\n\n<!-- Site Settings Footer Code -->\n\n\n<script>\ndocument.addEventListener(\"DOMContentLoaded\", () => {\n  if (typeof window.gsap === \"undefined\" || typeof window.ScrollTrigger === \"undefined\") {\n    console.warn(\"GSAP or ScrollTrigger not loaded.\");\n    return;\n  }\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Animate individual elements\n  document.querySelectorAll(\"[data-animate]:not([data-animate-group] [data-animate])\").forEach((el) => {\n    const animationType = el.dataset.animate || \"fade-up\";\n    const delay = parseFloat(el.dataset.delay) || 0;\n\n    const animations = {\n      \"fade-up\": { y: 50, opacity: 0 },\n      \"fade-down\": { y: -50, opacity: 0 },\n      \"fade-left\": { x: -50, opacity: 0 },\n      \"fade-right\": { x: 50, opacity: 0 },\n    };\n\n    const anim = animations[animationType] || animations[\"fade-up\"];\n\n    gsap.from(el, {\n      ...anim,\n      duration: 0.8,\n      delay: delay,\n      ease: \"power2.out\",\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\",\n        toggleActions: \"play none none none\",\n      },\n    });\n  });\n\n  // Animate groups with stagger\n  document.querySelectorAll(\"[data-animate-group]\").forEach((group) => {\n    const elements = group.querySelectorAll(\"[data-animate]\");\n    const staggerValue = parseFloat(group.dataset.stagger) || 0.2;\n\n    gsap.from(elements, {\n      y: 50,\n      opacity: 0,\n      duration: 0.8,\n      stagger: staggerValue,\n      ease: \"power2.out\",\n      scrollTrigger: {\n        trigger: group,\n        start: \"top 85%\",\n        toggleActions: \"play none none none\",\n      },\n    });\n  });\n});\n</script>\n</body></html>"
}