><img loading=\"lazy\" src=\"https://cdn.prod.website-files.com/68b04296fcd65c2e646de536/68b986df73b3d040087134ce_message-icon.svg\" alt=\"Message Icon\" class=\"image-7\"></div></div><div class=\"form-actions\"><input type=\"submit\" data-wait=\"Please wait...\" ms-code-submit-old=\"1\" class=\"hide w-button w-form-loading\" value=\"Send Inqury\" disabled=\"\"><div class=\"code-embed w-embed w-script\"><script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  const newSubmitButtons = document.querySelectorAll('[ms-code-submit-new]');\n\n  newSubmitButtons.forEach(newBtn => {\n    const submitId = newBtn.getAttribute('ms-code-submit-new');\n    const oldBtn = document.querySelector(`[ms-code-submit-old=\"${submitId}\"]`);\n\n    if (!oldBtn) {\n      console.error(`No matching old submit button found for ID: ${submitId}`);\n      return;\n    }\n\n    // Find the nested text span inside the new button\n    const newTextEl = newBtn.querySelector('.primary-btn-text');\n    if (!newTextEl) {\n      console.warn(`No .primary-btn-text found inside new button with ID: ${submitId}`);\n      return;\n    }\n\n    // Copy initial text from old to nested span in new\n    newTextEl.textContent = oldBtn.value;\n\n    // Sync when Webflow changes the old button (e.g. \"Please wait...\")\n    const observer = new MutationObserver(() => {\n      newTextEl.textContent = oldBtn.value;\n    });\n    observer.observe(oldBtn, { attributes: true });\n\n    // Handle click (forward to old button)\n    newBtn.addEventListener('click', function(e) {\n      e.preventDefault();\n      oldBtn.click();\n    });\n  });\n});\n</script></div><div ms-code-submit-new=\"1\" class=\"primary-btn\"><img src=\"https://cdn.prod.website-files.com/68b04296fcd65c2e646de536/68b585ab137b14fb2c3a7421_icons%20(2).svg\" loading=\"lazy\" alt=\"\"><div class=\"primary-btn-text\">Send Inqury</div><div class=\"w-embed\"><style>\n\t.primary-btn {\n    background-image: linear-gradient(\n      180deg,\n      rgba(0, 0, 0, 0.00) 0%,\n\t\t\trgba(0, 0, 0, 0.50) 60%,\n \t\t\trgba(0, 0, 0, 0.70) 100%\n    );\n    background-size: 100% 200%;\n    background-position: top;\n    transition: 0.3s ease;\n    transition-property: box-shadow, background-position;\n  }\n\n  .primary-btn:hover {\n    background-position: 10%;\n    box-shadow: 0 4px 12px 0 rgba(0, 0, 0, 0.15);\n  }\n</style></div></div></div></form><div class=\"w-form-done\" tabindex=\"-1\" role=\"region\" aria-label=\"Email Form success\"><div>Thank you! Your submission has been received!</div></div><div class=\"w-form-fail\" tabindex=\"-1\" role=\"region\" aria-label=\"Email Form failure\"><div>Oops! Something went wrong while submitting the form.</div></div></div></div></div></div></div><footer class=\"footer\"><div class=\"main\"><div class=\"footer-content\"><figure class=\"footer-logo\"><img src=\"https://cdn.prod.website-files.com/68b04296fcd65c2e646de536/68b09606f57558936254ddff_logomark.png\" loading=\"lazy\" alt=\"\" class=\"image-4\"></figure><div class=\"footer-menu\"><a data-wf--nav-menu-item--variant=\"light\" href=\"/privacy-policy\" class=\"nav-item w-variant-150f02ec-9ed2-c2d6-953d-1ba7f9bf11ad w-inline-block\"><img src=\"https://cdn.prod.website-files.com/68b04296fcd65c2e646de536/68b051563889a74f108c27ac_icons.svg\" loading=\"lazy\" alt=\"\" class=\"image-2\"><div class=\"text-block w-variant-150f02ec-9ed2-c2d6-953d-1ba7f9bf11ad\">Privacy Policy</div></a><a data-wf--nav-menu-item--variant=\"light\" href=\"/imprint\" class=\"nav-item w-variant-150f02ec-9ed2-c2d6-953d-1ba7f9bf11ad w-inline-block\"><img src=\"https://cdn.prod.website-files.com/68b04296fcd65c2e646de536/68b051563889a74f108c27ac_icons.svg\" loading=\"lazy\" alt=\"\" class=\"image-2\"><div class=\"text-block w-variant-150f02ec-9ed2-c2d6-953d-1ba7f9bf11ad\">Imprint</div></a></div></div></div></footer></div><script src=\"https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=68b04296fcd65c2e646de536\" type=\"text/ja