459\" name=\"sid\"><input id=\"lastgroupname\" type=\"hidden\" value=\"_WELCOME_SCREEN_\" name=\"lastgroupname\"><input id=\"LEMpostKey\" type=\"hidden\" value=\"1280830922\" name=\"LEMpostKey\"><input id=\"thisstep\" type=\"hidden\" value=\"0\" name=\"thisstep\">\n<script type=\"text/javascript\" id=\"lemscripts\">\n<!--\nvar LEMmode='group';\nvar LEMgseq=-1;\nExprMgr_process_relevance_and_tailoring = function(evt_type,sgqa,type){\nif (typeof LEM_initialized == 'undefined') {\nLEM_initialized=true;\nLEMsetTabIndexes();\n}\nif (evt_type == 'onchange' && (typeof last_sgqa !== 'undefined' && sgqa==last_sgqa) && (typeof last_evt_type !== 'undefined' && last_evt_type == 'TAB' && type != 'checkbox')) {\n  last_evt_type='onchange';\n  last_sgqa=sgqa;\n  return;\n}\nif (evt_type == 'updated'  && (typeof last_sgqa !== 'undefined' && sgqa==last_sgqa)) {\n  last_evt_type='updated';\n  last_sgqa=sgqa;\n  return;\n}\nlast_evt_type = evt_type;\nlast_sgqa=sgqa;\n\n}\nvar LEMalias2varName = {\n};\nvar LEMvarNameAttr = {\n};\n//-->\n</script>\n<input type=\"hidden\" id=\"aQuestionsWithDependencies\" data-qids=\"[]\">\n\n        \n<!-- Welcome Message -->\n<div id=\"welcome-container\" class=\"\">\n\n    <!-- Survey Name -->\n    <h1 class=\" survey-name  text-center\">\n         Can I use Benchtop NMR in my lab?\n    </h1>\n\n    <!-- Survey description -->\n    <div class=\" survey-description  text-info text-center\">\n        <p style=\"text-align:center;\">\ud83d\uddd3<span style=\"font-size:24px;\"><span style=\"color:#000000;\">22 June 2026</span></span></p>\n\n<p style=\"text-align:center;\">\ud83d\udd5b<span style=\"font-size:24px;\"><span style=\"color:#000000;\">3:00\u20135:00 p.m. CEST </span></span></p>\n\n<p style=\"text-align:center;\">\ud83d\udccc<span style=\"font-size:24px;\"><span style=\"color:#000000;\">via Zoom</span></span></p>\n\n    </div>\n\n    <!-- Welcome text -->\n    <div class=\" survey-welcome  h5 text-primary\">\n        <p style=\"text-align:justify;\">&nbsp;</p>\n\n<h2 style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:22px;\">We are pleased to invite you to our upcoming workshop,&nbsp;<strong>\u201c&nbsp;Can I use Benchtop NMR in my lab?\u201d</strong>&nbsp;taking place on&nbsp;<strong>22 June 2026, from 3:00\u20135:00 p.m. CEST via Zoom</strong>.</span></span></h2>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">Join us for an interactive workshop on how&nbsp;<strong>benchtop NMR</strong>&nbsp;can simplify and accelerate routine analytical and QC workflows \u2014 and how&nbsp;<strong>HQSpectrum</strong>&nbsp;can help turn molecular structures into reliable low-field reference spectra.</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">Benchtop NMR has strong potential to simplify and accelerate routine analytical workflows. But where does it truly add value, and how can it be implemented effectively?</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">This workshop shows how to turn benchtop NMR data into actionable decisions in everyday lab operations and to obtain reliable results with minimal interpretation effort.</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">Rather than focusing on theory alone, this practical session will enable you to assess whether benchtop NMR is applicable to your use cases.</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">As part of the session, Merck KGaA, Darmstadt, Germany will present ChemisTwin\u00ae, an online platform for automated NMR spectra interpretation supported by a database of digital Reference Materials (dRMs).</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">Q Magnetics will present the QM-125, a 125 MHz benchtop NMR with superb resolution and a flexible platform for walk-up use, automation, and hyphenation.</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><strong><span style=\"font-size:24px;\">What you will learn</span></strong></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">1.how to determine if benchtop NMR is a viable and cost-effective solution for their lab</span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">2.where benchtop NMR adds the most value in routine analysis workflows </span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">3.how to move from molecular structure to clear, decision-ready spectral insights </span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">4.practical tools and approaches to simplify spectrum interpretation</span></span></p>\n\n<h2 style=\"text-align:justify;\"><span style=\"color:#000000;\"><em><strong><span style=\"font-size:24px;\">Preliminary Agenda</span></strong></em></span></h2>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\"><strong>1. Welcome &amp; Workflow Framing&nbsp;</strong><strong>10 min | HQS</strong></span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\"><strong>2. From Measurement to Interpretation: Closing the Gap&nbsp;</strong><strong>30 min | </strong></span></span><span style=\"font-size:24px;\"><strong>Merck + QMagnetics&nbsp;</strong></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\"><strong>3. HQSpectrum in the Workflow: When and Why to Use It&nbsp;</strong><strong>25 min | HQS Chemistry Team</strong></span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\"><strong>4. Hands-On Session: Test Your Molecules</strong><strong>&nbsp;30 min | Interactive Session</strong></span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\"><strong>5. Discussion: Where This Fits in Your Lab&nbsp;</strong><strong>Optional | 20 min</strong></span></span></p>\n\n<p style=\"text-align:justify;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\"><strong>6. Key Takeaways &amp; Activation&nbsp;| 10 min</strong></span></span></p>\n\n<p style=\"text-align:justify;\">&nbsp;</p>\n\n<p style=\"text-align:center;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">A detailed agenda will be provided on our webpage and via email.</span></span></p>\n\n<p style=\"text-align:justify;\">&nbsp;</p>\n\n<p style=\"text-align:center;\"><span style=\"color:#000000;\"><span style=\"font-size:24px;\">Thank you for your interest in our upcoming workshop \u2014 we look forward to welcoming you!<br><br>This Webinar is hosted by HQS Quantum Simulations.<br>Visit our Webpage to explore more about our Solutions:&nbsp;<br><a href=\"https://quantumsimulations.de/\">www.quantumsimulations.de</a></span></span></p>\n\n<p style=\"text-align:justify;\">&nbsp;</p>\n\n<p style=\"text-align:justify;\">&nbsp;</p>\n\n    </div>\n\n    <!-- Question count -->\n    <div class=\" number-of-questions   text-muted\">\n        <div class=\" question-count-text \">\n\n                                                            There are 4 questions in this survey.\n                                  </div>\n  </div>\n</div>\n\n\n    \n<!-- Privacy message -->\n\n<div class=\" privacy  row\">\n    <div class=\"   col-12 col-centered\">\n                                                                                                                <div class=\"privacy-block\">\n         